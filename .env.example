# Copia este archivo como .env y cambia los valores en produccion.

# Entorno: "production" activa cookies seguras (HTTPS) y avisos de configuracion.
NODE_ENV=production

# Contrasena del panel /admin (usa una robusta en produccion)
ADMIN_PASSWORD=cambia-esta-contrasena

# Secreto para firmar las sesiones (usa una cadena larga y aleatoria).
# OBLIGATORIO en produccion: sin el, las sesiones se pierden en cada reinicio.
SESSION_SECRET=cambia-esto-por-algo-largo-y-secreto

# Token de acceso a la URL del panel admin.
# Si esta definido, /admin devuelve 404 a quien no lo lleve.
# Primera vez: /admin?token=tu-token  (guarda una cookie de 7 dias automaticamente)
# Si no se define, el panel queda accesible por URL directa (compatible hacia atras).
ADMIN_PATH_TOKEN=cambia-este-token-secreto

# Puerto del servidor
PORT=3000
